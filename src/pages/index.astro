---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import site from '../data/site.json';
import home from '../data/home.json';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = (await getCollection('portfolio'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const ig = site.social.instagram;
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__media"><img src={home.heroImage} alt="" /></div>
    <div class="hero__frame"></div>
    <div class="wrap hero__inner">
      <span class="eyebrow" data-reveal style="--d:.1s">{home.heroEyebrow}</span>
      <span class="script-accent hero-brand" data-reveal style="--d:.2s">{site.name}</span>
      <h1 data-reveal style="--d:.35s">{site.tagline}</h1>
      <p data-reveal style="--d:.55s">{home.heroIntro}</p>
      <p data-reveal style="--d:.72s; margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap;">
        <a class="btn btn--gold" href={site.cta.href}>{site.cta.label}</a>
        <a class="btn btn--ghost" href="/portfolio/">View Portfolio</a>
      </p>
    </div>
    <a class="scroll-cue" href="#intro" aria-label="Scroll down">Discover<span></span></a>
  </section>

  <!-- Marquee ribbon -->
  <Marquee />

  <!-- Intro -->
  <section class="section" id="intro">
    <div class="wrap narrow center" data-reveal>
      <span class="script-accent" style="display:block;">Welcome</span>
      <h2>{home.introHeading}</h2>
      <div class="ornament"><b>◆</b></div>
      <p style="color:var(--muted);">{home.introBody}</p>
      <p><a class="btn btn--ghost" href="/about/">Our Story</a></p>
    </div>
  </section>

  <!-- Philosophy pull-quote -->
  <section class="section bg-dark center has-watermark">
    <div class="watermark" aria-hidden="true"><span>Celebrate</span></div>
    <div class="wrap" style="display:flex; justify-content:center;">
      <p class="pullquote" data-reveal="scale">“{home.quote}”</p>
    </div>
  </section>

  <!-- Services -->
  <section class="section bg-alt">
    <div class="wrap">
      <div class="center" style="margin-bottom:3rem;" data-reveal>
        <span class="eyebrow">What We Offer</span>
        <h2>Services</h2>
        <div class="ornament"><b>◆</b></div>
      </div>
      <div class="grid grid--3">
        {services.map((s, i) => (
          <article class="card" data-reveal style={`--d:${i * 0.08}s`}>
            <span class="icon">{s.data.icon}</span>
            <h3>{s.data.title}</h3>
            <p>{s.data.summary}</p>
          </article>
        ))}
      </div>
      <p class="center" style="margin-top:3rem;" data-reveal><a class="btn btn--ghost" href="/services/">All Services</a></p>
    </div>
  </section>

  <!-- Portfolio preview -->
  {featured.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="center" style="margin-bottom:3rem;" data-reveal>
          <span class="eyebrow">Recent Work</span>
          <h2>Portfolio</h2>
          <div class="ornament"><b>◆</b></div>
        </div>
        <div class="grid grid--3">
          {featured.map((p, i) => (
            <a class={`tile${i === 0 ? ' tile--feature' : ''}`} href="/portfolio/" data-reveal style={`--d:${i * 0.1}s`}>
              <img src={p.data.cover} alt={p.data.title} loading="lazy" />
              <figcaption>
                {p.data.category && <span class="cat">{p.data.category}</span>}
                <h3>{p.data.title}</h3>
              </figcaption>
            </a>
          ))}
        </div>
        <p class="center" style="margin-top:3rem;" data-reveal><a class="btn btn--ghost" href="/portfolio/">View Full Portfolio</a></p>
      </div>
    </section>
  )}

  <!-- CTA band -->
  <section class="section bg-dark center has-watermark">
    <div class="watermark" aria-hidden="true"><span>Cheers</span></div>
    <div class="wrap narrow" data-reveal>
      <span class="script-accent" style="display:block; margin-bottom:0.2rem;">Let's create</span>
      <h2>{home.ctaHeading}</h2>
      <div class="ornament"><b>◆</b></div>
      <p style="color:rgba(255,249,240,0.85);">{home.ctaBody}</p>
      <p style="margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap; justify-content:center;">
        <a class="btn btn--gold" href={site.cta.href}>{site.cta.label}</a>
        {ig && <a class="btn btn--ghost" href={`https://instagram.com/${ig}`} target="_blank" rel="noopener">Follow @{ig}</a>}
      </p>
    </div>
  </section>
</Base>
