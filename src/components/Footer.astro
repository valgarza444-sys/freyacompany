---
import site from '../data/site.json';
const ig = site.social.instagram;
const year = 2026;
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <a class="brand" href="/">{site.name}</a>
      <p style="margin-top:1rem; max-width:34ch; color:rgba(255,249,240,0.7);">{site.tagline} — event styling for weddings, showers &amp; intimate celebrations in {site.serviceArea}.</p>
    </div>

    <div>
      <h4>Explore</h4>
      <ul>
        <li><a href="/services/">Services</a></li>
        <li><a href="/portfolio/">Portfolio</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href={site.cta.href}>{site.cta.label}</a></li>
      </ul>
    </div>

    <div>
      <h4>Connect</h4>
      <ul>
        {ig && <li><a href={`https://instagram.com/${ig}`} target="_blank" rel="noopener">Instagram @{ig}</a></li>}
        {site.email && <li><a href={`mailto:${site.email}`}>{site.email}</a></li>}
        {site.phone && <li><a href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}>{site.phone}</a></li>}
      </ul>
    </div>
  </div>

  <div class="wrap footer-bottom">
    <span>© {year} {site.name}. All rights reserved.</span>
    <span>{site.serviceArea}</span>
  </div>
</footer>
